# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
CREATORS_SPREADSHEET_ID=replace_with_spreadsheet_id
CREATORS_WORKSHEET=creators
RSS_WORKSHEET=rss_media

# AI Provider (OpenAI-compatible)
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Apollo.io
APOLLO_API_KEY=replace_with_apollo_api_key
APOLLO_BASE_URL=https://api.apollo.io/api/v1
APOLLO_REQUESTS_PER_MINUTE=50   
APOLLO_MAX_RETRIES=5
APOLLO_INITIAL_BACKOFF_SECONDS=2
APOLLO_SEARCH_MAX_PAGES=3
APOLLO_SEARCH_PER_PAGE=25
APOLLO_SEARCH_CONTACT_EMAIL_STATUSES=verified,likely to engage,unverified
APOLLO_ALLOWED_EMAIL_STATUSES=verified,valid,deliverable,safe,smtp_valid
NICHE_MATCH_MIN_CONFIDENCE=0.6

# Slack approval loop
SLACK_BOT_TOKEN=xoxb-replace_me
SLACK_APPROVAL_CHANNEL_ID=C0000000000
SLACK_APPROVAL_TIMEOUT_MINUTES=120
SLACK_POLL_INTERVAL_SECONDS=20

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=replace_with_smtp_user
SMTP_PASSWORD=replace_with_smtp_password
SMTP_FROM_EMAIL=sender@example.com
SMTP_USE_TLS=true
# Optional: multiple sender accounts (JSON array).
# For Gmail, use a 16-char App Password (spaces are allowed; code normalizes them).
# Optional per-account IMAP overrides: imap_host, imap_port, imap_username, imap_password.
# SMTP_ACCOUNTS=[{"label":"Main Gmail","host":"smtp.gmail.com","port":587,"username":"sender@example.com","password":"abcd efgh ijkl mnop","from_email":"sender@example.com","use_tls":true,"imap_host":"imap.gmail.com","imap_port":993,"imap_username":"sender@example.com","imap_password":"abcd efgh ijkl mnop"}]

# Workflow storage/logging
STATE_DB_PATH=./workflow_state.db
LOG_LEVEL=INFO

# Automation scheduling
OUTREACH_RUN_INTERVAL_HOURS=12
REPLY_CHECK_INTERVAL_SECONDS=300

# Optional API server for n8n trigger
API_HOST=127.0.0.1
API_PORT=8090
